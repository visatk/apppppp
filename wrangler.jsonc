{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "xterm",
	"main": "worker/index.ts",
	"compatibility_date": "2026-05-20",
	"assets": {
		"not_found_handling": "single-page-application"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	]
}
